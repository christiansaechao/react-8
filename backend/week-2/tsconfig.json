{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "target": "ES2022",
        "types": [
            "node"
        ],
        "sourceMap": true,
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "moduleDetection": "force"
    },
    "include": [
        "src"
    ]
}